{
    "name": "Casten: Bun",
    "dockerComposeFile": "compose.yml",
    "service": "bun",
    "workspaceFolder": "/workspace",
    "postCreateCommand": "bun i",
    "mounts": [
        "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.vscode-typescript-next"
            ]
        }
    }
}