{
	"name": "kasten-js",
	"version": "0.3.0",
	"author": "kkatou7209@gmail.com",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kkatou7209/kasten.git"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"sideEffects": false,
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^25.5.0",
		"rolldown": "^1.0.0-rc.9",
		"rolldown-plugin-dts": "^0.22.5"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"description": "TypeScript toolbox for encoding, decoding, and compression algorithms",
	"files": ["dist"],
	"keywords": [
		"codec",
		"encoding",
		"decoding",
		"encode",
		"decode",
		"base64",
		"base32",
		"base16",
		"run-length",
		"rle"
	],
	"license": "MIT",
	"scripts": {
		"build": "rolldown -c rolldown.config.ts",
		"prepublishOnly": "npm run build"
	},
	"type": "module",
	"types": "./dist/index.d.ts"
}
